printf("%g\n",$1);
}
;
expr: expr '+' term {$$=$1 + $3 ;}
     | term
     ;
term: term '*' factor  {$$=$1 * $3 ;}
     | factor
     ;
factor: '(' expr ')' {$$=$2 ;}
   | DIGIT

     ;
