/* test3.c */
 /* common subexpression elimination, and also of constant propagation */
#include <stdio.h>

 int main()
 {
     int a, b;
     int x, y, z;
     scanf("%d %d", &a, &b);
     x = a * b;

   if(b >= 4)
     {
         y = a * b;
         z = 0;
     }
     else
     {
         z = a * b * 4;
         y = 0;
     }

     printf("x = %d, y = %d, z = %d\n", x, y, z);
     return 0;
 }
