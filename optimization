#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <stdlib.h>
#define MAX 100
#define LEN 100
typedef struct {
    char lhs[20];
    char op1[20];
    char op[5];
    char op2[20];
    int valid;
} Expr;

Expr exprTable[MAX];
int exprCount = 0;

int isNumber(char *s) {
    int i = 0;
    if (s[0] == '-' && s[1] != '\0') i = 1;
    for (; s[i]; i++) {
        if (!isdigit((unsigned char)s[i])) return 0;
    }
    return 1;
}

void trim(char *s) {
    int i = 0, j;
    while (isspace((unsigned char)s[i])) i++;
    if (i > 0) {
        for (j = 0; s[i]; i++, j++) s[j] = s[i];
        s[j] = '\0';
    }

    int n = strlen(s);
    while (n > 0 && isspace((unsigned char)s[n - 1])) {
        s[n - 1] = '\0';
        n--;
    }
}

int sameExpr(char *a1, char *op, char *a2, Expr e) {
    return strcmp(a1, e.op1) == 0 &&
           strcmp(op, e.op) == 0 &&
           strcmp(a2, e.op2) == 0;
}

int main() {
    int n;
    char stmt[MAX][LEN];

    printf("Enter number of statements in basic block: ");
    scanf("%d", &n);
    getchar();

    printf("Enter three-address code statements:\n");
    for (int i = 0; i < n; i++) {
        fgets(stmt[i], LEN, stdin);
        stmt[i][strcspn(stmt[i], "\n")] = '\0';
        trim(stmt[i]);
    }

    printf("\nOptimized Basic Block:\n");

    for (int i = 0; i < n; i++) {
        char lhs[20], eq[5], op1[20], op[5], op2[20];

        // Try parsing form: x = y op z
        int count = sscanf(stmt[i], "%s = %s %s %s", lhs, op1, op, op2);

        if (count == 4) {
            // 1. Constant Folding
            if (isNumber(op1) && isNumber(op2)) {
                int a = atoi(op1);
                int b = atoi(op2);
                int result;

                if (strcmp(op, "+") == 0) result = a + b;
                else if (strcmp(op, "-") == 0) result = a - b;
                else if (strcmp(op, "*") == 0) result = a * b;
                else if (strcmp(op, "/") == 0 && b != 0) result = a / b;
                else {
                    printf("%s\n", stmt[i]);
                    continue;
                }

                printf("%s = %d\n", lhs, result);
                continue;
            }

            // 2. Algebraic Simplification
            if (strcmp(op, "+") == 0 && strcmp(op2, "0") == 0) {
                printf("%s = %s\n", lhs, op1);
                continue;
            }
            if (strcmp(op, "+") == 0 && strcmp(op1, "0") == 0) {
                printf("%s = %s\n", lhs, op2);
                continue;
            }
            if (strcmp(op, "-") == 0 && strcmp(op2, "0") == 0) {
                printf("%s = %s\n", lhs, op1);
                continue;
            }
            if (strcmp(op, "*") == 0 && strcmp(op2, "1") == 0) {
                printf("%s = %s\n", lhs, op1);
                continue;
            }
            if (strcmp(op, "*") == 0 && strcmp(op1, "1") == 0) {
                printf("%s = %s\n", lhs, op2);
                continue;
            }
            if (strcmp(op, "*") == 0 &&
                (strcmp(op1, "0") == 0 || strcmp(op2, "0") == 0)) {
                printf("%s = 0\n", lhs);
                continue;
            }
            if (strcmp(op, "/") == 0 && strcmp(op2, "1") == 0) {
                printf("%s = %s\n", lhs, op1);
                continue;
            }

            // 3. Common Subexpression Elimination
            int found = 0;
            for (int j = 0; j < exprCount; j++) {
                if (exprTable[j].valid && sameExpr(op1, op, op2, exprTable[j])) {
                    printf("%s = %s\n", lhs, exprTable[j].lhs);
                    found = 1;
                    break;
                }
            }

            if (!found) {
                printf("%s\n", stmt[i]);

                strcpy(exprTable[exprCount].lhs, lhs);
                strcpy(exprTable[exprCount].op1, op1);
                strcpy(exprTable[exprCount].op, op);
                strcpy(exprTable[exprCount].op2, op2);
                exprTable[exprCount].valid = 1;
                exprCount++;
            }
        }
        else {
            // Statements not in x = y op z form are printed as-is
            printf("%s\n", stmt[i]);
        }
    }

    return 0;
